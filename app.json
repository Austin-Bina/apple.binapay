{
  "expo": {
    "name": "BinaPay",
    "slug": "BinaPay",
    "version": "1.0.7",
    "orientation": "portrait",
    "runtimeVersion": "1.0.0",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.binapay",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 21,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.binapay",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data to ensure that your personal information and app data remain secure. Using Face ID provides an extra layer of protection, making sure that only you can access your sensitive data."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow $(PRODUCT_NAME) to access your contacts. We use this permission to fetch your contacts and select a contact to buy or gift services to."
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/04587ef0-aa8f-4c87-bcde-e89b00d969a3"
    },
    "extra": {
      "eas": {
        "projectId": "28111690-1e6a-44eb-88de-9e8025f5e7ee"
      }
    },
    "owner": "austin_bina"
  }
}
