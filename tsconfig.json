{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
     "lib": ["es2017", "dom", "es2020"],
    "allowJs": true,
    "jsx": "react-native",
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "strict": true,
    "moduleResolution": "bundler",   // ✅ replaces deprecated "node"
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",     // ✅ silences baseUrl deprecation warning
    "skipLibCheck": true,
    "paths": {
      "@navigators/*": ["./src/navigators/*"],
      "@components/*": ["./src/components/*"],
      "@screens/*": ["./src/screens/*"],
      "@constants/*": ["./src/constants/*"],
      "@utils/*": ["src/utils/*"],
      "@helpers/*": ["src/helpers/*"],
      "@config": ["./src/config"],
      "@env": ["./src/env"],
      "@assets/*": ["./src/assets/*"],
      "@store/*": ["./src/store/*"],
      "@lib/*": ["./src/lib/*"],
      "@type/*": ["src/type/*"],
      "@enum/*": ["./src/enum/*"],
      "@context/*": ["./src/context/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@contexts/*": ["src/contexts/*"],
      "@providers/*": ["src/providers/*"],
      "@templates/*": ["src/templates/*"]
    },
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ]
}
